<Window xmlns="https://github.com/avaloniaui"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:vm="using:OpenUtau.App.ViewModels"

        x:Class="OpenUtau.App.Views.ImportProjectDialog"

        Width="480" MinHeight="400" MaxHeight="720" SizeToContent="Height"

        WindowStartupLocation="CenterOwner"

        Icon="/Assets/open-utau.ico"

        Title="{DynamicResource dialogs.importproject.caption}"

        KeyDown="OnKeyDown">

  <Border Padding="16">

    <Grid RowDefinitions="*,Auto">

      <ScrollViewer Grid.Row="0" MaxHeight="560" HorizontalScrollBarVisibility="Disabled">

        <StackPanel Spacing="12">

          <TextBlock Text="{DynamicResource dialogs.importproject.message}" TextWrapping="Wrap"/>

          <TextBlock Text="{Binding FileName}" Opacity="0.7" TextWrapping="Wrap"/>

          <StackPanel Spacing="6">

            <StackPanel Orientation="Horizontal" Spacing="8">

              <CheckBox IsChecked="{Binding ImportNotes}" VerticalAlignment="Center"/>

              <TextBlock Text="{DynamicResource dialogs.importproject.notes}" VerticalAlignment="Center"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">

              <CheckBox IsChecked="{Binding ImportPitch}" IsEnabled="{Binding ImportNotes}" VerticalAlignment="Center"/>

              <TextBlock Text="{DynamicResource dialogs.importproject.pitch}" VerticalAlignment="Center"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">

              <CheckBox IsChecked="{Binding ImportTempo}" VerticalAlignment="Center"/>

              <TextBlock Text="{DynamicResource dialogs.importproject.tempo}" VerticalAlignment="Center"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">

              <CheckBox IsChecked="{Binding ImportTimeSignature}" VerticalAlignment="Center"/>

              <TextBlock Text="{DynamicResource dialogs.importproject.timesig}" VerticalAlignment="Center"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">

              <CheckBox IsChecked="{Binding FillShortGaps}" IsEnabled="{Binding ImportNotes}" VerticalAlignment="Center"/>

              <TextBlock Text="{DynamicResource dialogs.importproject.fillgaps}" VerticalAlignment="Center"/>

            </StackPanel>

            <Grid ColumnDefinitions="*,140" IsEnabled="{Binding FillShortGaps}">

              <TextBlock Grid.Column="0" Text="{DynamicResource dialogs.importproject.fillgaps.threshold}"

                         TextWrapping="Wrap" VerticalAlignment="Center"/>

              <ComboBox Grid.Column="1" ItemsSource="{Binding GapThresholdOptions}"

                        SelectedItem="{Binding SelectedGapThreshold}" Margin="8,0,0,0"

                        VerticalAlignment="Center" HorizontalAlignment="Stretch"/>

            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8">

              <CheckBox IsChecked="{Binding ResolveNoteOverlaps}" IsEnabled="{Binding ImportNotes}" VerticalAlignment="Center"/>

              <TextBlock Text="{DynamicResource dialogs.importproject.resolveoverlaps}" VerticalAlignment="Center"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">

              <CheckBox IsChecked="{Binding PartLeadingPadding}" IsEnabled="{Binding ImportNotes}" VerticalAlignment="Center"/>

              <TextBlock Text="{DynamicResource dialogs.importproject.leadingpadding}" VerticalAlignment="Center"/>

            </StackPanel>

            <Grid ColumnDefinitions="*,140" IsEnabled="{Binding PartLeadingPadding}">

              <TextBlock Grid.Column="0" Text="{DynamicResource dialogs.importproject.leadingpadding.size}"

                         TextWrapping="Wrap" VerticalAlignment="Center"/>

              <ComboBox Grid.Column="1" ItemsSource="{Binding LeadingPaddingOptions}"

                        SelectedItem="{Binding SelectedLeadingPadding}" Margin="8,0,0,0"

                        VerticalAlignment="Center" HorizontalAlignment="Stretch"/>

            </Grid>

          </StackPanel>

          <TextBlock Text="{DynamicResource dialogs.importproject.lyricssection}" FontWeight="SemiBold"/>

          <Grid ColumnDefinitions="Auto,*" IsEnabled="{Binding ImportNotes}">

            <TextBlock Grid.Column="0" Text="{DynamicResource dialogs.importproject.japanese}"

                       VerticalAlignment="Center" Margin="0,0,8,0"/>

            <ComboBox Grid.Column="1" ItemsSource="{Binding JapaneseLyricsOptions}"

                      SelectedItem="{Binding SelectedJapaneseLyrics}" HorizontalAlignment="Stretch"/>

          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding ImportNotes}">

            <CheckBox IsChecked="{Binding ConvertChineseToPinyin}" VerticalAlignment="Center"/>

            <TextBlock Text="{DynamicResource dialogs.importproject.chinesepinyin}" VerticalAlignment="Center"/>

          </StackPanel>

          <TextBlock Text="{DynamicResource dialogs.importproject.lyricsmapping}" IsEnabled="{Binding ImportNotes}"/>

          <TextBox Text="{Binding LyricsMappingText}" AcceptsReturn="True" TextWrapping="Wrap"

                   Height="64" IsEnabled="{Binding ImportNotes}"

                   Watermark="{DynamicResource dialogs.importproject.lyricsmapping.hint}"/>

          <TextBlock Text="{DynamicResource dialogs.importproject.lyricsreplace}" IsEnabled="{Binding ImportNotes}"/>

          <TextBox Text="{Binding LyricsReplacementText}" AcceptsReturn="True" TextWrapping="Wrap"

                   Height="64" IsEnabled="{Binding ImportNotes}"

                   Watermark="{DynamicResource dialogs.importproject.lyricsreplace.hint}"/>

          <Grid ColumnDefinitions="Auto,*">

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"

                       Text="{DynamicResource dialogs.importproject.defaultlyric}"/>

            <TextBox Grid.Column="1" Text="{Binding DefaultLyric}" Width="80" HorizontalAlignment="Left"/>

          </Grid>

        </StackPanel>

      </ScrollViewer>

      <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,12,0,0">

        <Button Content="{DynamicResource lyrics.cancel}" MinWidth="72" Click="OnCancel"/>

        <Button Content="{DynamicResource lyrics.apply}" MinWidth="72" Click="OnApply"/>

      </StackPanel>

    </Grid>

  </Border>

</Window>


