<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:OpenUtau.App.Views"
        mc:Ignorable="d" MinWidth="360" Width="360" Height="640"
        x:Class="OpenUtau.App.Views.ThemeEditorWindow" WindowStartupLocation="CenterOwner"
        Icon="/Assets/open-utau.ico"
        Title="{DynamicResource themeeditor.title}"
        Closing="WindowClosing" Topmost="True">
  <views:ThemeEditorPane x:Name="EditorPane"/>
</Window>
