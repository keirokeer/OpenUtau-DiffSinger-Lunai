  <Style Selector="Button.sideToolbarAction">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="MinWidth" Value="32" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="MaxWidth" Value="32" />
    <Setter Property="MaxHeight" Value="32" />
  </Style>
  <Style Selector="Button.sideToolbarAction /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>
  <Style Selector="Button.sideToolbarAction:pointerover /template/ ContentPresenter#PART_ContentPresenter,
          Button.sideToolbarAction:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource PianoRollSideHoverBackgroundBrush}" />
  </Style>
  <Style Selector="Button.sideToolbarAction TextBlock.sideToolbarGlyph">
    <Setter Property="Foreground" Value="{DynamicResource PianoRollSideIconOffBrush}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.sideToolbarAction:pointerover TextBlock.sideToolbarGlyph">
    <Setter Property="Foreground" Value="{DynamicResource PianoRollSideIconOffBrush}" />
  </Style>
  <Style Selector="Button.sideToolbarAction:pressed TextBlock.sideToolbarGlyph">
    <Setter Property="Foreground" Value="{DynamicResource ToolTipForegroundBrush}" />
  </Style>
  <!-- Checked + hover: outer 2px ring on full chip (no inset). -->
  <Style Selector="ToggleButton.sideToolbarToggle:checked:pointerover:not(.noteParamsToggle) /template/ ContentPresenter#PART_ContentPresenter,
          ToggleButton.sideToolbarToggle:checked:pressed:not(.noteParamsToggle) /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Margin" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppTopBarTransportStripBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle Path.filled">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Fill" Duration="0:0:0.15" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle Path.stroked,
          ToggleButton.sideToolbarToggle Ellipse.stroked">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Stroke" Duration="0:0:0.15" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle TextBlock.sideToolbarGlyph">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Foreground" Duration="0:0:0.15" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle Path.filled">
    <Setter Property="Fill" Value="{DynamicResource PianoRollSideIconOffBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle Path.stroked,
          ToggleButton.sideToolbarToggle Ellipse.stroked">
    <Setter Property="StrokeThickness" Value="1" />
    <Setter Property="Stroke" Value="{DynamicResource PianoRollSideIconOffBrush}" />
    <Setter Property="Fill" Value="Transparent" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle TextBlock.sideToolbarGlyph">
    <Setter Property="Foreground" Value="{DynamicResource PianoRollSideIconOffBrush}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:pointerover:not(:checked) Path.filled">
    <Setter Property="Fill" Value="{DynamicResource PianoRollSideIconOffBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:pointerover:not(:checked) Path.stroked,
          ToggleButton.sideToolbarToggle:pointerover:not(:checked) Ellipse.stroked">
    <Setter Property="Stroke" Value="{DynamicResource PianoRollSideIconOffBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:pointerover:not(:checked) TextBlock.sideToolbarGlyph">
    <Setter Property="Foreground" Value="{DynamicResource PianoRollSideIconOffBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle.tipsToggle TextBlock.sideToolbarGlyph">
    <Setter Property="Margin" Value="0,-4,0,0" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.tipsToggle TextBlock.sideToolbarGlyph">
    <Setter Property="Foreground" Value="{DynamicResource PianoRollSideAccentTipsBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.playToneToggle Path.filled">
    <Setter Property="Fill" Value="{DynamicResource PianoRollSideAccentPlayToneBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.livePitchToggle TextBlock.sideToolbarGlyph">
    <Setter Property="Foreground" Value="{DynamicResource PianoRollSideAccentLivePitchBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.livePitchFastToggle TextBlock.sideToolbarGlyph">
    <Setter Property="Foreground" Value="{DynamicResource PianoRollSideAccentLivePitchFastBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.vibratoToggle Path.stroked">
    <Setter Property="Stroke" Value="{DynamicResource PianoRollSideAccentVibratoBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.pitchToggle Path.stroked,
          ToggleButton.sideToolbarToggle:checked.pitchToggle Ellipse.stroked">
    <Setter Property="Stroke" Value="{DynamicResource PianoRollSideAccentPitchBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.finalPitchToggle Path.stroked">
    <Setter Property="Stroke" Value="{DynamicResource PianoRollSideAccentFinalPitchBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.waveformToggle Path.filled">
    <Setter Property="Fill" Value="{DynamicResource PianoRollSideAccentWaveformBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.phonemeToggle Path.stroked">
    <Setter Property="Stroke" Value="{DynamicResource PianoRollSideAccentPhonemeBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.expressionsToggle Path.stroked,
          ToggleButton.sideToolbarToggle:checked.expressionsToggle Ellipse.stroked">
    <Setter Property="Stroke" Value="{DynamicResource PianoRollSideAccentExpressionsBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.snapToggle Path.stroked">
    <Setter Property="Stroke" Value="{DynamicResource PianoRollSideAccentSnapBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.phonemizerTagsToggle Path.filled">
    <Setter Property="Fill" Value="{DynamicResource PianoRollSideAccentPhonemizerTagsBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:checked.appearanceToggle Path.filled">
    <Setter Property="Fill" Value="{DynamicResource ToolbarToolIconOnAccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle.noteParamsToggle:checked Path.filled,
          ToggleButton.sideToolbarToggle.noteParamsToggle:checked:pointerover Path.filled">
    <Setter Property="Fill" Value="{DynamicResource ToolbarToolIconOnAccentBrush}" />
  </Style>
  <!-- noteParams: local styles override Fluent :checked (PianoRoll StyleInclude > App). -->
  <Style Selector="ToggleButton.noteParamsToggle:checked /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="ToggleButton.noteParamsToggle:pointerover /template/ ContentPresenter#PART_ContentPresenter,
          ToggleButton.noteParamsToggle:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource PianoRollSideHoverBackgroundBrush}" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

</Styles>
