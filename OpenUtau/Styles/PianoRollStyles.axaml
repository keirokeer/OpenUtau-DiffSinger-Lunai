<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:OpenUtau.App.Controls">

  <Style Selector="Button,ToggleButton">
    <Setter Property="Focusable" Value="False"/>
  </Style>

  <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
    <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource SelectedTrackAccentBrush}"/>
  </Style>
  <Style Selector="CheckBox:checked:pointerover /template/ Border#NormalRectangle">
    <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentLightBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource SelectedTrackAccentLightBrush}"/>
  </Style>
  <Style Selector="CheckBox:checked:pressed /template/ Border#NormalRectangle">
    <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentDarkBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource SelectedTrackAccentDarkBrush}"/>
  </Style>

  <Style Selector="Path.checkmenu">
    <Setter Property="IsHitTestVisible" Value="False"/>
    <Setter Property="Data" Value="M1,5 L4,8 L9,1"/>
    <Setter Property="Stroke" Value="{DynamicResource SelectedTrackAccentBrush}"/>
    <Setter Property="StrokeThickness" Value="2"/>
    <Setter Property="Width" Value="12"/>
    <Setter Property="Height" Value="12"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentLightBrushSemi}"/>
  </Style>

  <Style Selector="Grid.toolbarIconHost, Border.toolbarIconHost">
    <Setter Property="Width" Value="24" />
    <Setter Property="Height" Value="24" />
  </Style>
  <!-- Side panel icons are authored for 18×18; layout grid keeps edge-aligned dots stable when scaling the outer host. -->
  <Style Selector="Grid.toolbarIconHostSideLayout">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Grid.toolbarIconHostSide, Border.toolbarIconHostSide">
    <Setter Property="Width" Value="22" />
    <Setter Property="Height" Value="22" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle Grid.toolbarIconHostSide,
          ToggleButton.sideToolbarToggle Border.toolbarIconHostSide">
    <Setter Property="RenderTransformOrigin" Value="50%,50%" />
    <Setter Property="RenderTransform">
      <ScaleTransform ScaleX="1.1" ScaleY="1.1" />
    </Setter>
  </Style>
  <Style Selector="ListBox.toolbar:not(.toolbarStrip)">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
  </Style>

  <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentLightBrushSemi}"/>
  </Style>

  <Style Selector="ListBoxItem.toolbar">
    <Setter Property="Foreground" Value="{DynamicResource ToolTipForegroundBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="MinHeight" Value="20"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="Width" Value="20"/>
    <Setter Property="Padding" Value="1"/>
    <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />

    <Style Selector="^:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource TransportToolbarOffHoverBrush}"/>
    </Style>
    <Style Selector="^:pressed /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource TransportToolbarOffPressedBrush}"/>
    </Style>
    <Style Selector="^:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
    </Style>
    <Style Selector="^:selected:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource TransportToolbarOnHoverBrush}"/>
    </Style>
    <Style Selector="^:selected:pressed /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource TransportToolbarOnHoverBrush}"/>
    </Style>
    <!-- Sub-tool chevron: do not use class "filled" — global ^ Path.filled would override Fill after :selected rules and hide the glyph on the dark chip. -->
    <Style Selector="^.hasSubTool /template/ Path#PART_SubToolArrow">
        <Setter Property="Opacity" Value="0.7" />
        <Setter Property="Fill" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    </Style>
    <Style Selector="^.hasSubTool:pointerover /template/ Path#PART_SubToolArrow">
        <Setter Property="Opacity" Value="1.0" />
    </Style>
    <Style Selector="^ /template/ Path#PART_ToolIcon.filled">
        <Setter Property="Fill" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    </Style>
    <Style Selector="^ Ellipse.stroked">
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Stroke" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    </Style>
    <Style Selector="^ Path.stroked">
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Stroke" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    </Style>
    <Style Selector="^:selected /template/ Path#PART_ToolIcon">
        <Setter Property="Fill" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
    </Style>
    <!-- When selected, keep sub-tool chevron visible (default template Opacity=0; :pointerover-only rules are not enough). -->
    <Style Selector="^.hasSubTool:selected /template/ Path#PART_SubToolArrow">
        <Setter Property="Opacity" Value="0.7" />
        <Setter Property="Fill" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
    </Style>
    <Style Selector="^.hasSubTool:selected:pointerover /template/ Path#PART_SubToolArrow">
        <Setter Property="Opacity" Value="1.0" />
    </Style>

    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_LayoutRoot"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="6">
          <Grid Classes="toolbarIconHost" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Path Name="PART_ToolIcon" Classes="filled">
              <Path.RenderTransform>
                <TransformGroup>
                  <ScaleTransform ScaleX=".92" ScaleY=".92" />
                  <TranslateTransform X="-1" Y="-1"/>
                </TransformGroup>
              </Path.RenderTransform>
            </Path>
            <Path Name="PART_SubToolArrow" 
                Data="M 0,4 L 4,4 L 4,0 Z" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Bottom"
                Margin="0,0,-1,-1"
                Opacity="0"
                ZIndex="1">
             <Path.RenderTransform>
                 <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
             </Path.RenderTransform>
          </Path>
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>
    <Style Selector="^ FlyoutPresenter">
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="0" />
    </Style>
  </Style>
  <Style Selector="ListBoxItem.toolbar:pointerover, ListBoxItem.toolbar:selected, ListBoxItem.toolbar:selected:pointerover, ListBoxItem.toolbar:pressed, ListBoxItem.toolbar:selected:pressed">
    <Setter Property="Foreground" Value="{DynamicResource ToolTipForegroundBrush}"/>
  </Style>

  <!-- Strip behind selection→knife: must follow ListBoxItem.toolbar so item Background stays transparent and strip shows. -->
  <Style Selector="ListBox.toolbar.toolbarStrip">
    <Setter Property="Background" Value="{DynamicResource PianoRollToolbarStripBackgroundBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="ListBox.toolbar.toolbarStrip ListBoxItem.toolbar">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="MinWidth" Value="32" />
    <Setter Property="Width" Value="32" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="ListBox.toolbar.toolbarStrip">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="MaxHeight" Value="32" />
  </Style>
  <!-- Piano roll top bar: separate 32×32 tool chips (no shared strip background). -->
  <Style Selector="ListBox.topBarToolStrip">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="MaxHeight" Value="32" />
  </Style>
  <Style Selector="ListBox.topBarToolStrip ListBoxItem.toolbar">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="MaxHeight" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="MinWidth" Value="32" />
    <Setter Property="MaxWidth" Value="32" />
    <Setter Property="Width" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="ListBox.topBarToolStrip ListBoxItem.toolbar /template/ Grid">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="ListBox.topBarToolStrip ListBoxItem.toolbar /template/ Path#PART_ToolIcon">
    <Setter Property="RenderTransform">
      <TransformGroup>
        <ScaleTransform ScaleX="0.72" ScaleY="0.72" />
        <TranslateTransform X="-2.5" Y="-2.5" />
      </TransformGroup>
    </Setter>
  </Style>
  <Style Selector="ListBox.topBarToolStrip ListBoxItem.toolbar /template/ Border#PART_LayoutRoot">
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="ListBox.topBarToolStrip ListBoxItem.toolbar:pointerover:not(:selected) /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource PianoRollSideHoverBackgroundBrush}" />
  </Style>
  <Style Selector="ListBox.topBarToolStrip ListBoxItem.toolbar:selected /template/ Border#PART_LayoutRoot,
          ListBox.topBarToolStrip ListBoxItem.toolbar:selected:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentBrushSemi}" />
  </Style>
  <Style Selector="ListBox.topBarToolStrip ListBoxItem.toolbar /template/ Path#PART_ToolIcon,
          ListBox.topBarToolStrip ListBoxItem.toolbar:selected /template/ Path#PART_ToolIcon,
          ListBox.topBarToolStrip ListBoxItem.toolbar:pointerover /template/ Path#PART_ToolIcon">
    <Setter Property="Fill" Value="{DynamicResource ToolbarToolIconOnAccentBrush}" />
  </Style>
  <Style Selector="ListBox.topBarToolStrip ListBoxItem.toolbar.hasSubTool /template/ Path#PART_SubToolArrow,
          ListBox.topBarToolStrip ListBoxItem.toolbar.hasSubTool:pointerover /template/ Path#PART_SubToolArrow,
          ListBox.topBarToolStrip ListBoxItem.toolbar.hasSubTool:selected /template/ Path#PART_SubToolArrow">
    <Setter Property="Fill" Value="{DynamicResource ToolbarToolIconOnAccentBrush}" />
    <Setter Property="Opacity" Value="0.7" />
  </Style>
  <Style Selector="ListBox.toolbar.toolbarStrip ListBoxItem.toolbar /template/ Border#PART_LayoutRoot">
    <Setter Property="CornerRadius" Value="0" />
  </Style>
  <Style Selector="ListBox.toolbar.toolbarStrip ListBoxItem.toolbar:pointerover:not(:selected) /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource PianoRollToolbarButtonHoverBrush}" />
  </Style>

  <!-- Expression panel tools: same chips as top bar, 24×24, workspace card / transport hover fills. -->
  <Style Selector="ListBox.expToolStrip">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="MaxHeight" Value="24" />
  </Style>
  <Style Selector="ListBox.expToolStrip ListBoxItem.toolbar">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="MaxHeight" Value="24" />
    <Setter Property="Height" Value="24" />
    <Setter Property="MinWidth" Value="24" />
    <Setter Property="MaxWidth" Value="24" />
    <Setter Property="Width" Value="24" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="ListBox.expToolStrip ListBoxItem.toolbar /template/ Grid.toolbarIconHost">
    <Setter Property="Width" Value="12" />
    <Setter Property="Height" Value="12" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="ListBox.expToolStrip ListBoxItem.toolbar /template/ Path#PART_ToolIcon">
    <Setter Property="Width" Value="12" />
    <Setter Property="Height" Value="12" />
    <Setter Property="Stretch" Value="Uniform" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="RenderTransform" Value="{x:Null}" />
  </Style>
  <Style Selector="ListBox.expToolStrip ListBoxItem.cursorTool /template/ Path#PART_ToolIcon">
    <Setter Property="RenderTransform">
      <TranslateTransform X="2" Y="0" />
    </Setter>
  </Style>
  <Style Selector="ListBox.expToolStrip ListBoxItem.toolbar /template/ Border#PART_LayoutRoot">
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Background" Value="{DynamicResource WorkspaceCardBrush}" />
  </Style>
  <Style Selector="ListBox.expToolStrip ListBoxItem.toolbar:pointerover:not(:selected) /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource PianoRollSideHoverBackgroundBrush}" />
  </Style>
  <Style Selector="ListBox.expToolStrip ListBoxItem.toolbar:selected /template/ Border#PART_LayoutRoot,
          ListBox.expToolStrip ListBoxItem.toolbar:selected:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource AppTopBarTransportHoverBrush}" />
  </Style>
  <Style Selector="ListBox.expToolStrip ListBoxItem.toolbar /template/ Path#PART_ToolIcon,
          ListBox.expToolStrip ListBoxItem.toolbar:selected /template/ Path#PART_ToolIcon,
          ListBox.expToolStrip ListBoxItem.toolbar:pointerover /template/ Path#PART_ToolIcon">
    <Setter Property="Fill" Value="{DynamicResource ToolbarToolIconOnAccentBrush}" />
  </Style>
  <Style Selector="ListBox.expToolStrip ListBoxItem.toolbar:pointerover,
          ListBox.expToolStrip ListBoxItem.toolbar:selected,
          ListBox.expToolStrip ListBoxItem.toolbar:selected:pointerover,
          ListBox.expToolStrip ListBoxItem.toolbar:pressed,
          ListBox.expToolStrip ListBoxItem.toolbar:selected:pressed">
    <Setter Property="Foreground" Value="{DynamicResource ToolTipForegroundBrush}" />
  </Style>
  <Style Selector="ListBox.expToolStrip ListBoxItem.toolbar:pressed:not(:selected) /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource PianoRollSideHoverBackgroundBrush}" />
  </Style>
  <Style Selector="ListBox.expToolStrip ListBoxItem.toolbar:selected:pressed /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource AppTopBarTransportHoverBrush}" />
  </Style>

  <Style Selector="Button.expToolButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.expToolButton /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource WorkspaceCardBrush}" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>
  <Style Selector="Button.expToolButton:pointerover /template/ ContentPresenter#PART_ContentPresenter,
          Button.expToolButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppTopBarTransportStripBrush}" />
  </Style>
  <Style Selector="Button.expToolButton Path.filled">
    <Setter Property="Fill" Value="{DynamicResource TransportChipIconOffBrush}" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Fill" Duration="0:0:0.15" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.expToolButton:pressed Path.filled">
    <Setter Property="Fill" Value="{DynamicResource ToolbarToolIconOnAccentBrush}" />
  </Style>

  <Style Selector="ListBoxItem.cursorTool /template/ Path#PART_ToolIcon">
    <Setter Property="Data" Value="M10.07,14.27C10.57,14.03 11.16,14.25 11.4,14.75L13.7,19.74L15.5,18.89L13.19,13.91C12.95,13.41 13.17,12.81 13.67,12.58L13.95,12.5L16.25,12.05L8,5.12V15.9L9.82,14.43L10.07,14.27M13.64,21.97C13.14,22.21 12.54,22 12.31,21.5L10.13,16.76L7.62,18.78C7.45,18.92 7.24,19 7,19A1,1 0 0,1 6,18V3A1,1 0 0,1 7,2C7.24,2 7.47,2.09 7.64,2.23L7.65,2.22L19.14,11.86C19.57,12.22 19.62,12.85 19.27,13.27C19.12,13.45 18.91,13.57 18.7,13.61L15.54,14.23L17.74,18.96C18,19.46 17.76,20.05 17.26,20.28L13.64,21.97Z" />
  </Style>
  <Style Selector="ListBoxItem.penTool /template/ Path#PART_ToolIcon">
    <Setter Property="Data" Value="M14.06,9L15,9.94L5.92,19H5V18.08L14.06,9M17.66,3C17.41,3 17.15,3.1 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18.17,3.09 17.92,3 17.66,3M14.06,6.19L3,17.25V21H6.75L17.81,9.94L14.06,6.19Z" />
  </Style>
  <Style Selector="ListBoxItem.penPlusTool /template/ Path#PART_ToolIcon">
    <Setter Property="Data" Value="M14.1,9L15,9.9L5.9,19H5V18.1L14.1,9M17.7,3C17.5,3 17.2,3.1 17,3.3L15.2,5.1L18.9,8.9L20.7,7C21.1,6.6 21.1,6 20.7,5.6L18.4,3.3C18.2,3.1 17.9,3 17.7,3M14.1,6.2L3,17.2V21H6.8L17.8,9.9L14.1,6.2M7,2V5H10V7H7V10H5V7H2V5H5V2H7Z" />
  </Style>
  <Style Selector="ListBoxItem.eraserTool /template/ Path#PART_ToolIcon">
    <Setter Property="Data" Value="M16.24,3.56L21.19,8.5C21.97,9.29 21.97,10.55 21.19,11.34L12,20.53C10.44,22.09 7.91,22.09 6.34,20.53L2.81,17C2.03,16.21 2.03,14.95 2.81,14.16L13.41,3.56C14.2,2.78 15.46,2.78 16.24,3.56M4.22,15.58L7.76,19.11C8.54,19.9 9.8,19.9 10.59,19.11L14.12,15.58L9.17,10.63L4.22,15.58Z" />
  </Style>
  <Style Selector="ListBoxItem.drawPitchTool /template/ Path#PART_ToolIcon">
    <Setter Property="Data" Value="M9.75 20.85C11.53 20.15 11.14 18.22 10.24 17C9.35 15.75 8.12 14.89 6.88 14.06C6 13.5 5.19 12.8 4.54 12C4.26 11.67 3.69 11.06 4.27 10.94C4.86 10.82 5.88 11.4 6.4 11.62C7.31 12 8.21 12.44 9.05 12.96L10.06 11.26C8.5 10.23 6.5 9.32 4.64 9.05C3.58 8.89 2.46 9.11 2.1 10.26C1.78 11.25 2.29 12.25 2.87 13.03C4.24 14.86 6.37 15.74 7.96 17.32C8.3 17.65 8.71 18.04 8.91 18.5C9.12 18.94 9.07 18.97 8.6 18.97C7.36 18.97 5.81 18 4.8 17.36L3.79 19.06C5.32 20 7.88 21.47 9.75 20.85M20.84 5.25C21.06 5.03 21.06 4.67 20.84 4.46L19.54 3.16C19.33 2.95 18.97 2.95 18.76 3.16L17.74 4.18L19.82 6.26M11 10.92V13H13.08L19.23 6.85L17.15 4.77L11 10.92Z" />
  </Style>
  <Style Selector="ListBoxItem.overwritePitchTool /template/ Path#PART_ToolIcon">
    <Setter Property="Data" Value="M 19.540126 3.1598821 C 19.330126 2.9498825 18.969979 2.9502481 18.759981 3.1602475 L 17.740128 4.1801 L 19.820028 6.2599998 L 20.840246 5.2500134 C 21.060246 5.0300138 21.060246 4.6700018 20.840246 4.4600022 L 19.540126 3.1598821 Z  M 17.149995 4.7702332 L 11.000186 10.920042 L 11.000186 12.999942 L 13.080086 12.999942 L 19.229895 6.8501331 L 17.149995 4.7702332 Z  M 19.879589 13.222841 L 17.879714 13.222475 L 17.879714 16.222471 L 14.879718 16.222471 L 14.879718 18.222712 L 17.879714 18.222712 L 17.879714 21.222708 L 19.879955 21.222708 L 19.879955 18.222712 L 22.879951 18.222712 L 22.879585 16.222837 L 19.879589 16.222837 L 19.879589 13.222841 Z  M 10.059992 11.260237 C 8.4999952 10.230239 6.499898 9.3198861 4.6399018 9.0498865 C 3.5799038 8.8898869 2.4599531 9.1097532 2.0999539 10.259751 C 1.7799545 11.249749 2.2898688 12.249906 2.8698676 13.029906 C 4.2398648 14.859902 6.369998 15.739794 7.9599948 17.31979 C 8.2999942 17.64979 8.7100549 18.040057 8.9100545 18.500057 C 9.1200541 18.940055 9.0701879 18.969971 8.6001889 18.969971 C 7.3601913 18.969971 5.8099483 17.999985 4.7999503 17.359985 L 3.7899638 19.059861 C 5.3199608 19.999859 7.8801301 21.469991 9.7501265 20.849993 C 11.530123 20.149993 11.139771 18.220057 10.239773 17.000059 C 9.349774 15.750061 8.1202131 14.889988 6.8802155 14.05999 C 6.0002173 13.49999 5.1901443 12.79982 4.5401455 11.999822 C 4.2601461 11.669822 3.6901105 11.059774 4.2701093 10.939774 C 4.8601081 10.819776 5.880071 11.399798 6.40007 11.619798 C 7.3100682 11.999798 8.2100072 12.440113 9.0500056 12.960113 L 10.059992 11.260237 Z" />
  </Style>
