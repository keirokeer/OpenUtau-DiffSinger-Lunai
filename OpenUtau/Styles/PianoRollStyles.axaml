  <Style Selector="Slider.fader">
    <Setter Property="Foreground" Value="{DynamicResource SelectedTrackAccentBrush}"/>

    <Style Selector="^:pointerover">
      <Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
        <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentLightBrush}" />
      </Style>
      <Style Selector="^ /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentLightBrush}" />
      </Style>
    </Style>

    <Style Selector="^:pressed">
      <Style Selector="^ /template/ RepeatButton#PART_DecreaseButton">
        <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentDarkBrush}" />
      </Style>
      <Style Selector="^ /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentDarkBrush}" />
      </Style>
    </Style>
  </Style>

  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{DynamicResource SelectedTrackAccentBrush}"/>
  </Style>

  <Style Selector="ToggleSwitch">
    <Style Selector="^:checked /template/ Border#SwitchKnobBounds">
      <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentBrush}" />
    </Style>
    <Style Selector="^:checked:pointerover /template/ Border#SwitchKnobBounds">
      <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentLightBrush}" />
    </Style>
    <Style Selector="^:checked:pressed /template/ Border#SwitchKnobBounds">
      <Setter Property="Background" Value="{DynamicResource SelectedTrackAccentDarkBrush}" />
    </Style>
  </Style>

  <Style Selector="RadioButton">
    <Setter Property="Padding" Value="0"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Template">
      <ControlTemplate TargetType="RadioButton">
        <StackPanel Orientation="Horizontal">
          <Border
          Name="RootBorder"
          Background="{TemplateBinding Background}"
          BorderBrush="{TemplateBinding BorderBrush}"
          BorderThickness="{TemplateBinding BorderThickness}"
          CornerRadius="{TemplateBinding CornerRadius}">
            <Grid ColumnDefinitions="20,*">
              <Grid Height="32" VerticalAlignment="Top">
                <Ellipse
                    Name="OuterEllipse"
                    Width="14"
                    Height="14"
                    Fill="{DynamicResource RadioButtonOuterEllipseFill}"
                    Stroke="{DynamicResource RadioButtonOuterEllipseStroke}"
                    StrokeThickness="{DynamicResource RadioButtonBorderThemeThickness}"
                    UseLayoutRounding="False" />

                <Ellipse
                    Name="CheckOuterEllipse"
                    Width="14"
                    Height="14"
                    Fill="{DynamicResource SelectedTrackAccentBrush}"
                    Opacity="0"
                    Stroke="{DynamicResource SelectedTrackAccentBrush}"
                    StrokeThickness="{DynamicResource RadioButtonBorderThemeThickness}"
                    UseLayoutRounding="False" />

                <Ellipse
                    Name="CheckGlyph"
                    Width="7"
                    Height="7"
                    Fill="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    Opacity="0"
                    Stroke="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    UseLayoutRounding="False" />
              </Grid>

              <ContentPresenter
                  Name="PART_ContentPresenter"
                  Grid.Column="1"
                  Margin="{TemplateBinding Padding}"
                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                  Content="{TemplateBinding Content}"
                  ContentTemplate="{TemplateBinding ContentTemplate}"
                  Foreground="{TemplateBinding Foreground}"
                  RecognizesAccessKey="True" />
            </Grid>
          </Border>
        </StackPanel>
      </ControlTemplate>
    </Setter>
    <Style Selector="^:pointerover /template/ Ellipse#OuterEllipse">
      <Setter Property="Stroke" Value="{DynamicResource RadioButtonOuterEllipseStrokePointerOver}" />
      <Setter Property="Fill" Value="{DynamicResource RadioButtonOuterEllipseFillPointerOver}" />
    </Style>
    <Style Selector="^:pointerover /template/ Ellipse#CheckOuterEllipse">
      <Setter Property="Stroke" Value="{DynamicResource SelectedTrackAccentLightBrush}" />
      <Setter Property="Fill" Value="{DynamicResource SelectedTrackAccentLightBrush}" />
    </Style>
    <Style Selector="^:pointerover /template/ Ellipse#CheckGlyph">
      <Setter Property="Stroke" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
      <Setter Property="Fill" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
    </Style>
  </Style>

  <Style Selector="c|PianoRollTopBarViewToggles">
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>
  <Style Selector="c|PianoRollTopBarViewToggles ToggleButton.sideToolbarToggle,
          c|PianoRollTopBarViewToggles Button.sideToolbarAction">
    <Setter Property="ToolTip.Placement" Value="Bottom" />
    <Setter Property="ToolTip.HorizontalOffset" Value="0" />
    <Setter Property="ToolTip.VerticalOffset" Value="4" />
  </Style>

  <Style Selector="Border.sideToolbarSeparator">
    <Setter Property="Background" Value="{DynamicResource TickLineBrushLow}"/>
  </Style>
  <Style Selector="StackPanel[Orientation=Vertical] > Border.sideToolbarSeparator">
    <Setter Property="Height" Value="1"/>
    <Setter Property="Margin" Value="6,6,6,4"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
  </Style>
  <Style Selector="StackPanel[Orientation=Horizontal] > Border.sideToolbarSeparator">
    <Setter Property="Width" Value="1"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="Margin" Value="4,0"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <!-- Left sidebar view/layer toggles -->
  <Style Selector="ToggleButton.sideToolbarToggle">
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="MinWidth" Value="32" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Background" Value="{DynamicResource WorkspaceCardBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ToolTipForegroundBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="ToolTip.Placement" Value="Right" />
    <Setter Property="ToolTip.HorizontalOffset" Value="4" />
    <Setter Property="ToolTip.VerticalOffset" Value="0" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource WorkspaceCardBrush}" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Margin" Value="0" />
  </Style>
  <Style Selector="ToggleButton.sideToolbarToggle:pointerover:not(:checked) /template/ ContentPresenter#PART_ContentPresenter,
          ToggleButton.sideToolbarToggle:pressed:not(:checked) /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource PianoRollSideHoverBackgroundBrush}" />
  </Style>
  <!-- Checked: 5% accent fill inset 2px (card shows in the margin ring). -->
