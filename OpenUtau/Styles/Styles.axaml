<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenUtau.App.ViewModels">
  <Style Selector="Control">
    <Style.Resources>
      <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
      <!-- Square corners for menus, flyouts, combo dropdowns (avoids hover rects vs rounded chrome). -->
      <CornerRadius x:Key="OverlayCornerRadius">0</CornerRadius>
      <x:Double x:Key="MenuFlyoutThemeMinHeight">20</x:Double>
      <Thickness x:Key="MenuFlyoutScrollerMargin">0</Thickness>
      <Thickness x:Key="ComboBoxDropdownContentMargin">0</Thickness>
    </Style.Resources>
  </Style>
  <Style Selector="Window">
    <Setter Property="FontFamily" Value="{DynamicResource ui.fontfamily}"/>
    <Setter Property="Icon" Value="/Assets/open-utau.ico"/>
  </Style>
  <!-- String ToolTip.Tip can inherit placement-target foreground; force white on root and text content. -->
  <Style Selector="ToolTip">
    <Setter Property="Foreground" Value="{StaticResource ToolTipForegroundBrush}"/>
  </Style>
  <Style Selector="ToolTip TextBlock">
    <Setter Property="Foreground" Value="{StaticResource ToolTipForegroundBrush}"/>
  </Style>
  <Style Selector="ToolTip AccessText">
    <Setter Property="Foreground" Value="{StaticResource ToolTipForegroundBrush}"/>
  </Style>
  <Style Selector="Menu">
    <Setter Property="Height" Value="24"/>
  </Style>
  <Style Selector="MenuItem">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Height" Value="24"/>
    <Setter Property="Padding" Value="8,2,8,2"/>
  </Style>
  <Style Selector="MenuItem /template/ Path#PART_ChevronPath">
    <Setter Property="RenderTransform" Value="Scale(0.75,0.75)"/>
    <Setter Property="Fill" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
  </Style>
  <Style Selector="MenuItem /template/ TextBlock#PART_InputGestureText">
    <Setter Property="Foreground" Value="{DynamicResource MenuFlyoutItemForeground}"/>
  </Style>
  <Style Selector="MenuItem:selected /template/ TextBlock#PART_InputGestureText">
    <Setter Property="Foreground" Value="{DynamicResource MenuFlyoutItemForegroundPointerOver}"/>
  </Style>
  <Style Selector="MenuItem:pressed /template/ TextBlock#PART_InputGestureText">
    <Setter Property="Foreground" Value="{DynamicResource MenuFlyoutItemForegroundPressed}"/>
  </Style>
  <Style Selector="MenuItem:disabled /template/ TextBlock#PART_InputGestureText">
    <Setter Property="Foreground" Value="{DynamicResource MenuFlyoutItemForegroundDisabled}"/>
  </Style>
  <Style Selector="MenuItem > Separator, ContextMenu > Separator">
    <Setter Property="Background" Value="{DynamicResource SystemControlHighlightBaseMediumHighBrush}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Margin" Value="2,0" />
    <Setter Property="Height" Value="1" />
  </Style>

  <Style Selector="MenuItem.MenuItemWithSubMenu MenuItem">
    <Setter Property="Header" Value="{Binding Header}"/>
    <Setter Property="Command" Value="{Binding Command}"/>
    <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>
    <Setter Property="Height" Value="{Binding Height}"/>
    <Setter Property="Icon" Value="{Binding Icon}"/>
  </Style>

  <Style Selector="ContextMenu MenuItem">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Padding" Value="4,2,4,2"/>
  </Style>

  <Style Selector="ContextMenu.WithCommand MenuItem">
    <Setter Property="Header" Value="{Binding Header}"/>
    <Setter Property="Command" Value="{Binding Command}"/>
    <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>
  </Style>

  <Style Selector="Path.checkmenu">
    <Setter Property="IsHitTestVisible" Value="False"/>
    <Setter Property="Data" Value="M1,5 L4,8 L9,1"/>
    <Setter Property="Stroke" Value="{DynamicResource AccentBrush1}"/>
    <Setter Property="StrokeThickness" Value="2"/>
    <Setter Property="Width" Value="12"/>
    <Setter Property="Height" Value="12"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="FontSize" Value="12"/>
  </Style>
  <Style Selector="Label">
    <Setter Property="FontSize" Value="12"/>
  </Style>
  <Style Selector="TextBox">
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="MinHeight" Value="20"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="Padding" Value="4,1"/>
    <Setter Property="Margin" Value="0,0,0,4"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="VerticalAlignment" Value="Top"/>
    <Setter Property="SelectionBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
    <Setter Property="SelectionForegroundBrush" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
  </Style>
  <Style Selector="TextBox:disabled">
    <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="Margin" Value="0,4"/>
    <Setter Property="Padding" Value="4,0,4,2"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Template">
      <ControlTemplate>
        <ContentPresenter x:Name="PART_ContentPresenter"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Content="{TemplateBinding Content}"
                          ContentTemplate="{TemplateBinding ContentTemplate}"
                          Padding="{TemplateBinding Padding}"
                          RecognizesAccessKey="False"
                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="Button:pressed, RepeatButton:pressed, ToggleButton:pressed">
    <Setter Property="RenderTransform" Value="scale(1)"/>
  </Style>
  <Style Selector="Button.clear">
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="Margin" Value="0,4"/>
    <Setter Property="Padding" Value="4,0,4,2"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.clear:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource TransportToolbarOffHoverBrush}"/>
  </Style>
  <Style Selector="Button.clear.trackHeaderTextButton">
    <Setter Property="CornerRadius" Value="4" />
  </Style>
  <Style Selector="Button.clear.trackHeaderTextButton.muted">
    <Setter Property="Foreground" Value="{DynamicResource MutedIconBrush}"/>
  </Style>
  <Style Selector="Button.clear.trackHeaderTextButton:pointerover /template/ ContentPresenter#PART_ContentPresenter,
          Button.clear.trackHeaderTextButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppTopBarTransportStripBrush}" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="Button.transportChrome">
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="Button.transportChrome:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource TransportToolbarOffHoverBrush}"/>
  </Style>
  <Style Selector="Button.transportChrome:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource TransportToolbarOffPressedBrush}"/>
  </Style>

  <Style Selector="ToggleButton.normal">
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="Margin" Value="0,4"/>
    <Setter Property="Padding" Value="4,0,4,2"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />

    <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource NeutralAccentBrush}" />
    </Style>
    <Style Selector="^:pressed  /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource NeutralAccentBrushPointerOver}" />
    </Style>
    <Style Selector="^:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource NeutralAccentBrushSemi}" />
    </Style>
    <Style Selector="^:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource NeutralAccentBrush}" />
    </Style>
    <Style Selector="^:checked:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource NeutralAccentBrushPointerOver}" />
    </Style>
  </Style>

  <Style Selector="ToggleButton.toolbar">
    <Setter Property="Foreground" Value="{DynamicResource ToolTipForegroundBrush}"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="Margin" Value="0,4"/>
    <Setter Property="Padding" Value="4,0,4,2"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />

    <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TransportToolbarOffHoverBrush}" />
    </Style>
    <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TransportToolbarOffPressedBrush}" />
    </Style>
    <Style Selector="^:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    </Style>
    <Style Selector="^:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TransportToolbarOnHoverBrush}" />
    </Style>
    <Style Selector="^:checked:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TransportToolbarOnHoverBrush}" />
    </Style>

    <Style Selector="^ Path.filled">
      <Setter Property="Fill" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    </Style>
    <Style Selector="^ Ellipse.stroked">
      <Setter Property="StrokeThickness" Value="1"/>
      <Setter Property="Stroke" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    </Style>
    <Style Selector="^ Path.stroked">
      <Setter Property="StrokeThickness" Value="1"/>
      <Setter Property="Stroke" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    </Style>
    <!-- Checked fill = ForegroundBaseHigh: ink must be panel background for contrast. -->
    <Style Selector="^:checked Path.filled">
      <Setter Property="Fill" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
    </Style>
    <Style Selector="^:checked Path.stroked">
      <Setter Property="Stroke" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
    </Style>
    <Style Selector="^:checked Ellipse.stroked">
      <Setter Property="Stroke" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
    </Style>
  </Style>
  <Style Selector="ToggleButton.toolbar TextBlock.toolbarGlyphText">
    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    <Setter Property="FontSize" Value="15" />
  </Style>
  <Style Selector="ToggleButton.toolbar:checked TextBlock.toolbarGlyphText">
    <Setter Property="Foreground" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
  </Style>
  <Style Selector="ToggleButton.toolbar:pointerover, ToggleButton.toolbar:pressed, ToggleButton.toolbar:checked, ToggleButton.toolbar:checked:pointerover, ToggleButton.toolbar:checked:pressed">
    <Setter Property="Foreground" Value="{DynamicResource ToolTipForegroundBrush}"/>
  </Style>

  <Style Selector="ToggleButton.switch">
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Padding" Value="6,2"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <Style Selector="ToggleSwitch /template/ Border#SwitchKnobBounds">
    <Setter Property="Background" Value="{DynamicResource AccentBrush1Note}"/>
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{DynamicResource SystemRegionBrush}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="MinHeight" Value="20"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="Margin" Value="0,4"/>
    <Setter Property="Padding" Value="4,0,0,2"/>
  </Style>
  <Style Selector="ComboBoxItem">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="MinHeight" Value="20"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="Margin" Value="0"/>
    <Setter Property="Padding" Value="4,2,0,0"/>
  </Style>
  <Style Selector="ComboBox /template/ Path#DropDownGlyph">
    <Setter Property="Fill" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="MinHeight" Value="24"/>
    <Setter Property="Height" Value="24"/>
    <Setter Property="Padding" Value="4"/>
    <Setter Property="Margin" Value="0"/>
  </Style>

  <Style Selector="CheckBox">
    <Setter Property="MinHeight" Value="20" />
    <Setter Property="MinWidth" Value="20" />
  </Style>
  <Style Selector="CheckBox /template/ Grid">
    <Setter Property="Height" Value="20" />
    <Setter Property="Width" Value="20" />
  </Style>
  <Style Selector="CheckBox /template/ Border#NormalRectangle">
    <Setter Property="VerticalAlignment" Value="Top" />
  </Style>
  <Style Selector="CheckBox /template/ Viewbox">
    <Setter Property="VerticalAlignment" Value="Top" />
  </Style>

  <Style Selector="CheckBox.menu">
    <Setter Property="IsHitTestVisible" Value="False" />
    <Style Selector="^:unchecked /template/ Border#NormalRectangle">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="^:checked /template/ Path#CheckGlyph">
      <Setter Property="Fill" Value="{DynamicResource AccentBrush1}" />
      <Setter Property="Width" Value="12" />
    </Style>
    <Style Selector="^:checked /template/ Border#NormalRectangle">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent"/>
    </Style>
  </Style>

  <Style Selector="DataGridColumnHeader">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="MinHeight" Value="20" />
  </Style>
  <Style Selector="DataGridCell">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="MinHeight" Value="20" />
  </Style>
  <Style Selector="DataGridCell > TextBox">
    <Setter Property="Margin" Value="0"/>
  </Style>

  <Style Selector="ProgressBar">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush1}"/>
  </Style>

  <Style Selector="Grid.workspaceLayout">
    <Setter Property="Background" Value="{DynamicResource WorkspaceCanvasBrush}" />
  </Style>
  <Style Selector="Border.workspaceCard">
    <Setter Property="Background" Value="{DynamicResource WorkspaceCardBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4" />
  </Style>
  <!-- Docked workspace tiles: flush to screen on outer edges; 8px gap only between blocks. -->
  <Style Selector="Border.workspaceDockTop">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>
  <Style Selector="Border.workspaceDockTracks">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Margin" Value="0,0,0,0" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="Border.workspaceDockPianoHost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Margin" Value="0" />
  </Style>
  <Style Selector="Border.workspaceDockPianoRollSide">
    <Setter Property="CornerRadius" Value="0,8,8,0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="Padding" Value="8" />
  </Style>
  <Style Selector="Border.workspaceCard.workspaceDockAppearance,
                 Border.workspaceDockAppearance">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="ClipToBounds" Value="False" />
  </Style>
  <Style Selector="Border.workspaceCard.workspaceDockThemeEditor,
                 Border.workspaceDockThemeEditor">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="ClipToBounds" Value="False" />
  </Style>
  <Style Selector="Border.workspaceDockPianoRoll,
                 Border.workspaceDockPianoRollMain,
                 Border.workspaceDockPianoRollPhoneme,
                 Border.workspaceDockPianoRollExp">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="Border.workspaceDockPianoRoll.FlushRight,
                 Border.workspaceDockPianoRollMain.FlushRight,
                 Border.workspaceDockPianoRollPhoneme.FlushRight,
                 Border.workspaceDockPianoRollExp.FlushRight">
    <Setter Property="CornerRadius" Value="8,0,0,8" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="Border.workspaceDockPianoRoll.FlushLeft,
                 Border.workspaceDockPianoRollMain.FlushLeft,
                 Border.workspaceDockPianoRollPhoneme.FlushLeft,
                 Border.workspaceDockPianoRollExp.FlushLeft">
    <Setter Property="CornerRadius" Value="0,8,8,0" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="Border.workspaceDockPianoRoll.FlushLeft.FlushRight,
                 Border.workspaceDockPianoRollMain.FlushLeft.FlushRight,
                 Border.workspaceDockPianoRollPhoneme.FlushLeft.FlushRight,
                 Border.workspaceDockPianoRollExp.FlushLeft.FlushRight">
    <Setter Property="CornerRadius" Value="0,0,0,0" />
  </Style>
  <Style Selector="Border.workspaceDockPianoRollMain.FlushRight > Grid > Border.pianoRollTopBar,
                 Border.workspaceDockPianoRoll.FlushRight > Grid > Border.pianoRollTopBar">
    <Setter Property="Padding" Value="8,8,8,8" />
  </Style>
  <Style Selector="Border.workspaceCard.workspaceDockNoteProps,
                 Border.workspaceDockNoteProps">
    <Setter Property="CornerRadius" Value="8,0,0,8" />
    <Setter Property="Margin" Value="0" />
    <!-- Match piano-roll dock: no top card inset so header aligns with Edit/View row. -->
    <Setter Property="Padding" Value="0" />
    <Setter Property="ClipToBounds" Value="False" />
  </Style>
  <Style Selector="TextBlock.workspacePanelTitle">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Opacity" Value="0.55" />
    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
  </Style>
  <Style Selector="TextBlock.notePropsPanelTitle">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.workspacePanelClose">
    <Setter Property="Width" Value="32"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Opacity" Value="0.65"/>
  </Style>
  <Style Selector="Button.workspacePanelClose:pointerover">
    <Setter Property="Opacity" Value="1"/>
    <Setter Property="Background" Value="{DynamicResource NeutralAccentBrushSemi2}"/>
  </Style>
  <Style Selector="Button.workspacePanelClose Path">
    <Setter Property="Stroke" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
    <Setter Property="StrokeThickness" Value="1.5"/>
    <Setter Property="Stretch" Value="Uniform"/>
    <Setter Property="Width" Value="10"/>
    <Setter Property="Height" Value="10"/>
    <Setter Property="Data" Value="M3,3 L11,11 M11,3 L3,11"/>
  </Style>

  <!-- Welcome (home) screen -->
  <Style Selector="Border.welcomeCard">
    <Setter Property="Background" Value="{DynamicResource WorkspaceCardBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="12" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>
  <Style Selector="Border.welcomeHubShell">
    <Setter Property="Background" Value="{DynamicResource WorkspaceCardBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="12,12,12,8" />
    <Setter Property="ClipToBounds" Value="False" />
  </Style>
  <Style Selector="Button.welcomeRecoveryButton">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="FontSize" Value="12" />
  </Style>
  <Style Selector="Button.welcomeActionButton">
    <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="8" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="MinHeight" Value="56" />
  </Style>
  <Style Selector="Button.welcomeActionButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource PianoRollSideHoverBackgroundBrush}" />
  </Style>
  <Style Selector="Button.welcomeActionButton:pressed">
    <Setter Property="Background" Value="{DynamicResource PianoRollSideHoverBackgroundBrush}" />
  </Style>
  <Style Selector="Button.singerHubInstallButton">
    <Setter Property="Margin" Value="0" />
    <Setter Property="Padding" Value="8,5,8,3" />
    <Setter Property="Height" Value="24" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.welcomeActionTitle">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
  </Style>
  <Style Selector="TextBlock.welcomeActionDescription">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Opacity" Value="0.55" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="ListBox.welcomeFileList">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="ListBox.welcomeFileList ListBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="Margin" Value="0,1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="MinHeight" Value="44" />
    <Setter Property="Height" Value="NaN" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="ListBox.welcomeFileList ListBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource PianoRollSideHoverBackgroundBrush}" />
  </Style>
  <Style Selector="ListBox.welcomeFileList ListBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource PianoRollSideHoverBackgroundBrush}" />
  </Style>
  <Style Selector="TextBlock.welcomeFileName">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
  </Style>
  <Style Selector="TextBlock.welcomeFilePath">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Opacity" Value="0.55" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <!-- Main window top bar: 32px chrome, 8px padding top and bottom (48px total). -->
  <Style Selector="Border.appTopBar">
    <Setter Property="Padding" Value="8,8,8,8" />
  </Style>
  <Style Selector="Border.appTopBar > Grid">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>
  <Style Selector="Border.appTopBar Menu">
    <Setter Property="Height" Value="32" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Border.appTopBar Menu > MenuItem">
    <Setter Property="FontSize" Value="12" />
