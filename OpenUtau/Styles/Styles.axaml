  <Style Selector="Border.pianoRollTopBar Button.topBarTextChip:pointerover /template/ ContentPresenter#PART_ContentPresenter,
          Border.pianoRollTopBar Button.topBarTextChip:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource PianoRollSideHoverBackgroundBrush}" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>
  <Style Selector="Border.pianoRollTopBar Button.topBarTextChip TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.workspaceDockPianoRollSide > StackPanel">
    <Setter Property="Spacing" Value="0" />
  </Style>

  <Style Selector="Border.tips">
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource NeutralAccentBrushSemi}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="2"/>
    <Setter Property="IsHitTestVisible" Value="False"/>
  </Style>
  <Style Selector="TextBlock.tips">
    <Setter Property="LineHeight" Value="18"/>
  </Style>

  <!-- Thin overlay scrollbars: pill thumb on content, no arrow buttons or track fill. -->
  <Style Selector="ScrollBar.overlay">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="AllowAutoHide" Value="False" />
  </Style>
  <Style Selector="ScrollBar.overlay:horizontal">
    <Setter Property="MinHeight" Value="10" />
    <Setter Property="MaxHeight" Value="10" />
  </Style>
  <Style Selector="ScrollBar.overlay:vertical">
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="MaxHeight" Value="Infinity" />
    <Setter Property="MinWidth" Value="10" />
    <Setter Property="MaxWidth" Value="10" />
  </Style>
  <Style Selector="ScrollBar.overlay /template/ Rectangle#TrackRect">
    <Setter Property="Fill" Value="Transparent" />
    <Setter Property="Stroke" Value="Transparent" />
    <Setter Property="Opacity" Value="0" />
  </Style>
  <Style Selector="ScrollBar.overlay:horizontal /template/ Thumb">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Template">
      <ControlTemplate TargetType="Thumb">
        <Border x:Name="PART_Border"
                Height="8"
                MinHeight="8"
                MaxHeight="8"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch"
                Background="{DynamicResource ScrollBarThumbBrush}"
                Opacity="0.85"
                CornerRadius="4"
                BorderThickness="0"
                ClipToBounds="True"/>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="ScrollBar.overlay:vertical /template/ Thumb">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="Template">
      <ControlTemplate TargetType="Thumb">
        <Border x:Name="PART_Border"
                Width="8"
                MinWidth="8"
                MaxWidth="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="{DynamicResource ScrollBarThumbBrush}"
                Opacity="0.85"
                CornerRadius="4"
                BorderThickness="0"
                ClipToBounds="True"/>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="ScrollBar.overlay /template/ Thumb:pointerover /template/ Border#PART_Border">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Background" Value="#C4C4C4" />
  </Style>
  <Style Selector="ScrollBar.overlay /template/ Thumb:pressed /template/ Border#PART_Border">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Background" Value="#D9D9D9" />
  </Style>
  <Style Selector="ScrollBar.overlay /template/ RepeatButton#PART_LineUpButton,
                 ScrollBar.overlay /template/ RepeatButton#PART_LineDownButton">
    <Setter Property="IsVisible" Value="False" />
    <Setter Property="IsHitTestVisible" Value="False" />
    <Setter Property="Opacity" Value="0" />
    <Setter Property="Width" Value="0" />
    <Setter Property="Height" Value="0" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="MaxWidth" Value="0" />
    <Setter Property="MaxHeight" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="ScrollBar.overlay /template/ RepeatButton#PART_LineUpButton PathIcon,
                 ScrollBar.overlay /template/ RepeatButton#PART_LineDownButton PathIcon,
                 ScrollBar.overlay /template/ RepeatButton#PART_LineUpButton /template/ Border,
                 ScrollBar.overlay /template/ RepeatButton#PART_LineDownButton /template/ Border,
                 ScrollBar.overlay /template/ RepeatButton#PART_LineUpButton /template/ ContentPresenter,
                 ScrollBar.overlay /template/ RepeatButton#PART_LineDownButton /template/ ContentPresenter">
    <Setter Property="IsVisible" Value="False" />
    <Setter Property="Opacity" Value="0" />
  </Style>
  <Style Selector="ScrollBar.overlay /template/ RepeatButton#PART_PageUpButton,
                 ScrollBar.overlay /template/ RepeatButton#PART_PageDownButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Opacity" Value="0" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="ScrollViewer.workspaceDockPanelScroll">
    <Setter Property="ClipToBounds" Value="False"/>
  </Style>
  <Style Selector="ScrollViewer.workspaceDockPanelScroll.overlay /template/ ScrollBar:vertical">
    <Setter Property="Margin" Value="0"/>
    <Setter Property="Width" Value="10"/>
    <Setter Property="MinWidth" Value="10"/>
    <Setter Property="MaxWidth" Value="10"/>
  </Style>
  <Style Selector="ScrollViewer.workspaceScroll:not(.workspaceDockPanelScroll).overlay /template/ ScrollBar:vertical /template/ Thumb">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="Template">
      <ControlTemplate TargetType="Thumb">
        <Border x:Name="PART_Border"
                Width="8"
                MinWidth="8"
                MaxWidth="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="{DynamicResource ScrollBarThumbBrush}"
                Opacity="0.85"
                CornerRadius="4"
                BorderThickness="0"
                ClipToBounds="True"/>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="ScrollViewer.workspaceScroll:not(.workspaceDockPanelScroll).overlay /template/ ScrollBar:vertical /template/ Thumb:pointerover /template/ Border#PART_Border">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Background" Value="#C4C4C4" />
  </Style>
  <Style Selector="ScrollViewer.workspaceScroll:not(.workspaceDockPanelScroll).overlay /template/ ScrollBar:vertical /template/ Thumb:pressed /template/ Border#PART_Border">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Background" Value="#D9D9D9" />
  </Style>
  <Style Selector="ScrollViewer.workspaceScroll.workspaceDockPanelScroll.overlay /template/ ScrollBar:vertical /template/ Thumb">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="Template">
      <ControlTemplate TargetType="Thumb">
        <Border x:Name="PART_Border"
                Width="8"
                MinWidth="8"
                MaxWidth="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="{DynamicResource ScrollBarThumbBrush}"
                Opacity="0.85"
                CornerRadius="4"
                BorderThickness="0"
                ClipToBounds="True"/>
      </ControlTemplate>
    </Setter>
  </Style>

  <!-- Avalonia 11 Fluent ScrollBar.music: style colors/corners only; never set Thumb size or alignment (breaks drag and viewport ratio). -->
  <Style Selector="ScrollBar.music[IsExpanded=True] /template/ Rectangle#TrackRect,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=True] /template/ Rectangle#TrackRect">
    <Setter Property="Fill" Value="Transparent" />
    <Setter Property="Stroke" Value="Transparent" />
  </Style>
  <Style Selector="ScrollBar.music[IsExpanded=true] /template/ Thumb,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ Thumb">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Background" Value="{DynamicResource ScrollBarThumbBrush}" />
  </Style>
  <Style Selector="ScrollBar.music[IsExpanded=true] /template/ Thumb /template/ Border,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ Thumb /template/ Border">
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Background" Value="{DynamicResource ScrollBarThumbBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="ScrollBar.music[IsExpanded=true] /template/ Thumb:pointerover,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ Thumb:pointerover">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Background" Value="{DynamicResource NeutralAccentBrush}" />
  </Style>
  <Style Selector="ScrollBar.music[IsExpanded=true] /template/ Thumb:pointerover /template/ Border,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ Thumb:pointerover /template/ Border">
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Background" Value="{DynamicResource NeutralAccentBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <!-- Line buttons: icon tint on hover only (no fill), like ViewScaler. -->
  <Style Selector="ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton /template/ ContentPresenter#PART_ContentPresenter,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton /template/ ContentPresenter#PART_ContentPresenter,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton:pointerover /template/ ContentPresenter#PART_ContentPresenter,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton:pointerover /template/ ContentPresenter#PART_ContentPresenter,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton:pressed /template/ ContentPresenter#PART_ContentPresenter,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton:pressed /template/ ContentPresenter#PART_ContentPresenter,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton /template/ ContentPresenter#PART_ContentPresenter,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton /template/ ContentPresenter#PART_ContentPresenter,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton:pointerover /template/ ContentPresenter#PART_ContentPresenter,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton:pointerover /template/ ContentPresenter#PART_ContentPresenter,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton:pressed /template/ ContentPresenter#PART_ContentPresenter,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton /template/ Border#PART_BorderElement,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton /template/ Border#PART_BorderElement,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton:pointerover /template/ Border#PART_BorderElement,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton:pointerover /template/ Border#PART_BorderElement,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton:pressed /template/ Border#PART_BorderElement,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton:pressed /template/ Border#PART_BorderElement,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton /template/ Border#PART_BorderElement,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton /template/ Border#PART_BorderElement,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton:pointerover /template/ Border#PART_BorderElement,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton:pointerover /template/ Border#PART_BorderElement,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton:pressed /template/ Border#PART_BorderElement,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton:pressed /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton PathIcon,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton PathIcon,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton PathIcon,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton PathIcon">
    <Setter Property="Foreground" Value="{DynamicResource NeutralAccentBrushSemi}" />
  </Style>
  <Style Selector="ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton:pointerover PathIcon,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton:pointerover PathIcon,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton:pressed PathIcon,
                 ScrollBar.music[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton:pressed PathIcon,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton:pointerover PathIcon,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton:pointerover PathIcon,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineUpButton:pressed PathIcon,
                 ScrollViewer.workspaceScroll /template/ ScrollBar[IsExpanded=true] /template/ RepeatButton#PART_LineDownButton:pressed PathIcon">
    <Setter Property="Foreground" Value="{DynamicResource NeutralAccentBrush}" />
  </Style>

  <Style Selector="HeaderedContentControl.groupbox">
    <Setter Property="Margin" Value="5"/>
    <Setter Property="Background" Value="{StaticResource SystemControlBackgroundAltHighBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource SystemControlForegroundBaseMediumBrush}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate>
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border ZIndex="1" Padding="2,0,2,0" Background="{TemplateBinding Background}" Margin="5,0,0,0">
              <TextBlock Text="{TemplateBinding Header, Converter={x:Static vm:ObjectToStringConverter.Instance}}"/>
            </Border>
            <Border Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="0,8,0,0" Padding="12,12,12,8"
                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                    CornerRadius="6">
              <ContentPresenter Content="{TemplateBinding Content}" />
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style Selector="Slider.fader">
    <Setter Property="Focusable" Value="False"/>
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush1}"/>
    <Setter Property="Template">
      <ControlTemplate>
        <DataValidationErrors>
          <Border>
            <Grid x:Name="SliderContainer">
              <Track
                  Name="PART_Track"
                  Minimum="{TemplateBinding Minimum}"
                  Maximum="{TemplateBinding Maximum}"
                  Value="{TemplateBinding Value, Mode=TwoWay}"
                  IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                  Orientation="Horizontal">
                <Track.DecreaseButton>
                  <RepeatButton
                      Name="PART_DecreaseButton"
                      Theme="{StaticResource FluentSliderHorizontalRepeatButton}"
                      Background="{TemplateBinding Foreground}"
                      Focusable="False"/>
                </Track.DecreaseButton>
                <Track.IncreaseButton>
                  <RepeatButton
                      Name="PART_IncreaseButton"
                      Theme="{StaticResource FluentSliderHorizontalRepeatButton}"
                      Background="{TemplateBinding Background}"
                      Focusable="False"/>
                </Track.IncreaseButton>
                <Thumb
                    Name="thumb"
                    Width="{DynamicResource SliderHorizontalThumbWidth}"
                    Height="{DynamicResource SliderHorizontalThumbHeight}"
                    Margin="0"
                    Padding="0"
                    Background="{TemplateBinding Foreground}"
                    BorderThickness="0"
                    Theme="{StaticResource FluentSliderThumbTheme}"
                    DataContext="{TemplateBinding Value}"/>
              </Track>
            </Grid>
          </Border>
        </DataValidationErrors>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="Slider:pointerover /template/ RepeatButton#PART_DecreaseButton">
    <Setter Property="Background" Value="{DynamicResource AccentBrush1}" />
  </Style>
  <Style Selector="Slider.fader /template/ Thumb">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}" Height="6" Width="16" CornerRadius="6"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style Selector="Expander" >
    <Setter Property="Margin" Value="4,2" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="IsExpanded" Value="True" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Background" Value="Transparent" />

    <Style Selector="^:down /template/ ToggleButton#ExpanderHeader">
      <Setter Property="Height" Value="32"/>
      <Setter Property="MinHeight" Value="32"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style Selector="^:down /template/ ToggleButton#ExpanderHeader /template/ Border#ExpandCollapseChevronBorder">
      <Setter Property="Height" Value="20"/>
    </Style>
    <Style Selector="^:down /template/ ToggleButton#ExpanderHeader /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Margin" Value="7,0,0,0"/>
    </Style>
  </Style>

  <Style Selector="ColorPicker TextBox">
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="CornerRadius" Value="0,6,6,0"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="Padding" Value="5"/>
    <Setter Property="Margin" Value="0"/>
  </Style>

</Styles>
