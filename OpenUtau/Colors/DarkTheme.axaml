<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <system:Boolean x:Key="IsDarkMode">true</system:Boolean>
  
  <Color x:Key="BackgroundColor">#252525</Color>
  <Color x:Key="BackgroundColorPointerOver">#2F2F2F</Color>
  <Color x:Key="TransportToolbarOffHoverColor">#3A3A3A</Color>
  <Color x:Key="BackgroundColorPressed">#2F2F2F</Color>
  <Color x:Key="BackgroundColorDisabled">#252525</Color>

  <Color x:Key="ForegroundColor">#F0F0F0</Color>
  <Color x:Key="ForegroundColorPointerOver">#FCFCFC</Color>
  <Color x:Key="ForegroundColorPressed">#FCFCFC</Color>
  <Color x:Key="ForegroundColorDisabled">#A6A6A6</Color>

  <Color x:Key="BorderColor">#E0E0E0</Color>
  <Color x:Key="BorderColorPointerOver">#FCFCFC</Color>

  <Color x:Key="SystemAccentColor">#7271C9</Color> <!-- need to fix -->
  <!-- PointerOver -->
  <Color x:Key="SystemAccentColorLight1">#E0E0E0</Color>
  <!-- Pressed -->
  <Color x:Key="SystemAccentColorDark1">#B6B6B6</Color>

  <Color x:Key="NeutralAccentColor">#FCFCFC</Color>
  <Color x:Key="NeutralAccentColorPointerOver">#FCFCFC</Color>
  <Color x:Key="AccentColor1">#E0E0E0</Color>
  <Color x:Key="AccentColor1Note">#4C4C7A</Color>
  <Color x:Key="AccentColor2">#7271C9</Color>
  <Color x:Key="AccentColor3">#FCFCFC</Color>

  <Color x:Key="NoteBorderColor">#7B79D9</Color>
  <Color x:Key="NoteBorderColorPressed">#ADACFC</Color>

  <Color x:Key="TickLineColor">#0E0E0E</Color>
  <Color x:Key="BarNumberColor">#E0E0E0</Color>
  <Color x:Key="FinalPitchColor">#CAFFFFFF</Color>
  <Color x:Key="TrackBackgroundAltColor">#2F2F2F</Color>
  
  <Color x:Key="WarningColor">#433519</Color>

  <Color x:Key="ToolbarCheckedHoverColor">#D8D8D8</Color>
  <Color x:Key="ToolTipForegroundColor">#FFFFFF</Color>
  <Color x:Key="WorkspaceCanvasColor">#151515</Color>
  <!-- Card surface = main panel fill; stripes use TrackBackgroundAlt on top. -->
  <Color x:Key="WorkspaceCardColor">#222222</Color>
  <Color x:Key="WorkspaceElevatedSurfaceColor">#292929</Color>
  <Color x:Key="MutedIconColor">#808080</Color>
  <Color x:Key="PianoRollWaveformPeakColor">#59B5B5B5</Color>
  <Color x:Key="PianoRollToolbarStripColor">#202020</Color>
  <Color x:Key="PianoRollToolbarButtonHoverColor">#313131</Color>
  <Color x:Key="AppTopBarTransportStripColor">#323232</Color>
  <Color x:Key="AppTopBarTransportHoverColor">#454545</Color>
  <Color x:Key="AppTopBarValueStripColor">#1C1C1C</Color>
  <Color x:Key="AppTopBarValueDividerColor">#3A3A3A</Color>

  <!--Keyboard Background-->
  <Color x:Key="WhiteKeyColorLeft">#C0C0C0</Color>
  <Color x:Key="WhiteKeyColorRight">#F0F0F0</Color>
  <Color x:Key="ToolbarCheckedPianoLightColor">#F0F0F0</Color>
  <Color x:Key="WhiteKeyNameColor">#222222</Color>

  <Color x:Key="CenterKeyColorLeft">#A9A6CD</Color>
  <Color x:Key="CenterKeyColorRight">#D3CFFF</Color>
  <Color x:Key="CenterKeyNameColor">#4433FF</Color>

  <Color x:Key="BlackKeyColorLeft">Transparent</Color>
  <Color x:Key="BlackKeyColorRight">Transparent</Color>
  <Color x:Key="BlackKeyNameColor">#FCFCFC</Color>
</ResourceDictionary>
