<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="SystemRegionBrush"
                   Color="{DynamicResource BackgroundColor}"/>
  <!-- Transport / piano-roll toolbar: unified hover (off), slightly lighter than panel pointer-over. -->
  <SolidColorBrush x:Key="TransportToolbarOffHoverBrush"
                   Color="{DynamicResource TransportToolbarOffHoverColor}"/>
  <SolidColorBrush x:Key="TransportToolbarOffPressedBrush"
                   Color="{DynamicResource BackgroundColorPressed}"/>
  <!-- Hover on “on” (lit) toggles: slightly dimmer than ForegroundColor / icon white (ToolbarCheckedHoverColor per theme). -->
  <SolidColorBrush x:Key="TransportToolbarOnHoverBrush"
                   Color="{DynamicResource ToolbarCheckedHoverColor}"/>
  <!-- Always white: string tips must not inherit placement-target foreground (e.g. checked toolbar toggles). -->
  <SolidColorBrush x:Key="ToolTipForegroundBrush" Color="{DynamicResource ToolTipForegroundColor}"/>
  <SolidColorBrush x:Key="WorkspaceCanvasBrush"
                   Color="{DynamicResource WorkspaceCanvasColor}"/>
  <SolidColorBrush x:Key="WorkspaceCardBrush"
                   Color="{DynamicResource WorkspaceCardColor}"/>
  <SolidColorBrush x:Key="WorkspaceElevatedSurfaceBrush"
                   Color="{DynamicResource WorkspaceElevatedSurfaceColor}"/>
  <SolidColorBrush x:Key="MutedIconBrush"
                   Color="{DynamicResource MutedIconColor}"/>
  <SolidColorBrush x:Key="PianoRollToolbarStripBackgroundBrush"
                   Color="{DynamicResource PianoRollToolbarStripColor}"/>
  <SolidColorBrush x:Key="AppTopBarTransportStripBrush"
                   Color="{DynamicResource AppTopBarTransportStripColor}"/>
  <SolidColorBrush x:Key="AppTopBarTransportHoverBrush"
                   Color="{DynamicResource AppTopBarTransportHoverColor}"/>
  <!-- Main window transport chips -->
  <SolidColorBrush x:Key="TransportChipIconOffBrush" Color="{DynamicResource MutedIconColor}"/>
  <SolidColorBrush x:Key="TransportAccentPlayPauseBrush" Color="#4CBD6A"/>
  <SolidColorBrush x:Key="TransportAccentMetronomeBrush" Color="#5EC8E8"/>
  <!-- Track header -->
  <SolidColorBrush x:Key="TrackHeaderSelectedBackgroundBrush" Color="{DynamicResource WorkspaceElevatedSurfaceColor}"/>
  <SolidColorBrush x:Key="TrackHeaderUnselectedBorderBrush" Color="{DynamicResource MutedIconColor}"/>
  <SolidColorBrush x:Key="TrackAccentMuteBrush" Color="#E85A5A"/>
  <SolidColorBrush x:Key="TrackAccentMuteCheckedBrush" Color="#E85A5A" Opacity="0.08"/>
  <SolidColorBrush x:Key="TrackAccentSoloBrush" Color="#4CBD6A"/>
  <SolidColorBrush x:Key="TrackAccentSoloCheckedBrush" Color="#4CBD6A" Opacity="0.08"/>
  <SolidColorBrush x:Key="AppTopBarValueStripBrush"
                   Color="{DynamicResource AppTopBarValueStripColor}"/>
  <SolidColorBrush x:Key="AppTopBarValueDividerBrush"
                   Color="{DynamicResource AppTopBarValueDividerColor}"/>
  <SolidColorBrush x:Key="PianoRollToolbarButtonHoverBrush"
                   Color="{DynamicResource PianoRollToolbarButtonHoverColor}"/>
  <LinearGradientBrush x:Key="PianoRollTimelineStripBrush" StartPoint="0%,0%" EndPoint="0%,100%">
    <GradientStop Color="{DynamicResource PianoRollTimelineStripColor}" Offset="0"/>
    <GradientStop Color="{DynamicResource WorkspaceCardColor}" Offset="1"/>
  </LinearGradientBrush>
  <!-- Piano roll left sidebar toggles -->
  <SolidColorBrush x:Key="PianoRollSideIconOffBrush" Color="{DynamicResource MutedIconColor}"/>
  <SolidColorBrush x:Key="PianoRollSideHoverBackgroundBrush" Color="{DynamicResource AppTopBarTransportStripColor}"/>
  <SolidColorBrush x:Key="PianoRollSideAccentTipsBrush" Color="#8E9AAB"/>
  <SolidColorBrush x:Key="PianoRollSideAccentPlayToneBrush" Color="#E5A84A"/>
  <SolidColorBrush x:Key="PianoRollSideAccentLivePitchBrush" Color="#52C4E8"/>
  <SolidColorBrush x:Key="PianoRollSideAccentLivePitchFastBrush" Color="#FF9F43"/>
  <SolidColorBrush x:Key="PianoRollSideAccentVibratoBrush" Color="#B87FD4"/>
  <SolidColorBrush x:Key="PianoRollSideAccentPitchBrush" Color="#5BA8F2"/>
  <SolidColorBrush x:Key="PianoRollSideAccentFinalPitchBrush" Color="#4ABFA8"/>
  <SolidColorBrush x:Key="PianoRollSideAccentWaveformBrush" Color="#6FA882"/>
  <SolidColorBrush x:Key="PianoRollSideAccentPhonemeBrush" Color="#D48AAF"/>
  <SolidColorBrush x:Key="PianoRollSideAccentExpressionsBrush" Color="#E07855"/>
  <SolidColorBrush x:Key="PianoRollSideAccentRealCurvesBrush" Color="#A8B8D8"/>
  <SolidColorBrush x:Key="PianoRollSideAccentSnapBrush" Color="#7E94B2"/>
  <SolidColorBrush x:Key="PianoRollSideAccentPhonemizerTagsBrush" Color="#9D8FDC"/>
  <SolidColorBrush x:Key="PianoRollSideAccentTipsCheckedBrush" Color="#8E9AAB" Opacity="0.10"/>
  <SolidColorBrush x:Key="PianoRollSideAccentPlayToneCheckedBrush" Color="#E5A84A" Opacity="0.10"/>
  <SolidColorBrush x:Key="PianoRollSideAccentLivePitchCheckedBrush" Color="#52C4E8" Opacity="0.10"/>
  <SolidColorBrush x:Key="PianoRollSideAccentLivePitchFastCheckedBrush" Color="#FF9F43" Opacity="0.10"/>
  <SolidColorBrush x:Key="PianoRollSideAccentVibratoCheckedBrush" Color="#B87FD4" Opacity="0.10"/>
  <SolidColorBrush x:Key="PianoRollSideAccentPitchCheckedBrush" Color="#5BA8F2" Opacity="0.10"/>
  <SolidColorBrush x:Key="PianoRollSideAccentFinalPitchCheckedBrush" Color="#4ABFA8" Opacity="0.10"/>
  <SolidColorBrush x:Key="PianoRollSideAccentWaveformCheckedBrush" Color="#6FA882" Opacity="0.10"/>
  <SolidColorBrush x:Key="PianoRollSideAccentPhonemeCheckedBrush" Color="#D48AAF" Opacity="0.10"/>
  <SolidColorBrush x:Key="PianoRollSideAccentExpressionsCheckedBrush" Color="#E07855" Opacity="0.10"/>
  <SolidColorBrush x:Key="PianoRollSideAccentRealCurvesCheckedBrush" Color="#A8B8D8" Opacity="0.10"/>
  <SolidColorBrush x:Key="PianoRollSideAccentSnapCheckedBrush" Color="#7E94B2" Opacity="0.10"/>
  <SolidColorBrush x:Key="PianoRollSideAccentPhonemizerTagsCheckedBrush" Color="#9D8FDC" Opacity="0.10"/>
  <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush"
                   Color="{DynamicResource BackgroundColor}"/>
  <SolidColorBrush x:Key="BackgroundBrushSemi"
                   Color="{DynamicResource BackgroundColor}" Opacity="0.5"/>
  <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrushPointerOver"
                   Color="{DynamicResource BackgroundColorPointerOver}"/>
  <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrushDisabled"
                   Color="{DynamicResource BackgroundColorDisabled}"/>
  <SolidColorBrush x:Key="SystemControlBackgroundBaseLowBrush"
                   Color="{DynamicResource BackgroundColorPointerOver}"/>
  <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrush"
                   Color="{DynamicResource ForegroundColor}" />
  <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrushPointerOver"
                   Color="{DynamicResource ForegroundColorPointerOver}" />
  <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrushDisabled"
                   Color="{DynamicResource ForegroundColorDisabled}" />
  <SolidColorBrush x:Key="SystemControlForegroundBaseMediumBrush"
                   Color="{DynamicResource BorderColor}" />
  <SolidColorBrush x:Key="SystemControlHighlightBaseMediumHighBrush"
                   Color="{DynamicResource BorderColorPointerOver}" />
  <SolidColorBrush x:Key="SystemControlDisabledBaseMediumLowBrush"
                   Color="{DynamicResource ForegroundColorDisabled}" />
  <SolidColorBrush x:Key="SystemControlHighlightAltBaseHighBrush"
                   Color="{DynamicResource ForegroundColorPointerOver}" />
  <SolidColorBrush x:Key="SystemControlHighlightBaseHighBrush"
                   Color="{DynamicResource ForegroundColorPointerOver}" />
  <SolidColorBrush x:Key="MenuFlyoutPresenterBackground"
                   Color="{DynamicResource BackgroundColor}" />
  <SolidColorBrush x:Key="MenuFlyoutItemBackground"
                   Color="{DynamicResource BackgroundColor}" />
  <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPointerOver"
                   Color="{DynamicResource BackgroundColorPointerOver}" />
  <SolidColorBrush x:Key="MenuFlyoutItemBackgroundDisabled"
                   Color="{DynamicResource BackgroundColorDisabled}" />
  <SolidColorBrush x:Key="MenuFlyoutItemForeground"
                   Color="{DynamicResource ForegroundColor}" />
  <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver"
                   Color="{DynamicResource ForegroundColorPointerOver}" />
  <SolidColorBrush x:Key="MenuFlyoutItemForegroundDisabled"
                   Color="{DynamicResource ForegroundColorDisabled}" />
  <!--combo box background-->
  <SolidColorBrush x:Key="SystemControlBackgroundAltMediumLowBrush"
                   Color="{DynamicResource BackgroundColorPointerOver}" />
  <!--combo box pointer over-->
  <SolidColorBrush x:Key="SystemControlPageBackgroundAltMediumBrush"
                   Color="{DynamicResource BackgroundColorPressed}" />
  <!--combo box flyout background-->
  <SolidColorBrush x:Key="SystemControlTransientBackgroundBrush"
                   Color="{DynamicResource BackgroundColorPointerOver}" />
  <!--combo box highlight overlay-->
  <SolidColorBrush x:Key="SystemControlHighlightListLowBrush"
                   Color="{DynamicResource ForegroundColorPressed}" Opacity="0.25" />
  <!--text box disabled text-->
  <SolidColorBrush x:Key="SystemControlDisabledChromeDisabledLowBrush"
                   Color="{DynamicResource ForegroundColorDisabled}" />
  <!--text box disabled background-->
  <SolidColorBrush x:Key="TextControlBackgroundDisabled"
                   Color="{DynamicResource BackgroundColorDisabled}" />
  <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumLowBrush"
                   Color="{DynamicResource BackgroundColorPointerOver}"/>
  <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundBrush"
                   Color="{DynamicResource BackgroundColorPointerOver}" />
  <SolidColorBrush x:Key="DataGridColumnHeaderForegroundBrush"
                   Color="{DynamicResource ForegroundColor}" />
  <SolidColorBrush x:Key="DataGridScrollBarsSeparatorBackground"
                   Color="{DynamicResource BackgroundColor}" />
  <!--botton background pointer over overlap-->
  <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                   Color="{DynamicResource ForegroundColorPressed}" Opacity="0.25" />
  <SolidColorBrush x:Key="ButtonBackgroundDisabled"
                   Color="{DynamicResource BackgroundColorDisabled}" />
  <SolidColorBrush x:Key="MenuFlyoutPresenterBorderBrush"
                   Color="{DynamicResource BorderColor}" />

  <SolidColorBrush x:Key="TickLineBrush"
                   Color="{DynamicResource TickLineColor}" />
  <SolidColorBrush x:Key="TickLineBrushLow"
                   Color="{DynamicResource TickLineColor}" Opacity="0.5"/>
  <SolidColorBrush x:Key="BarNumberBrush"
                   Color="{DynamicResource BarNumberColor}" />
  <SolidColorBrush x:Key="FinalPitchBrush"
                   Color="{DynamicResource FinalPitchColor}" />
  <SolidColorBrush x:Key="RealCurveStrokeBrush"
                   Color="{DynamicResource AccentColor1}" Opacity="0.25" />
  <LinearGradientBrush x:Key="RealCurveFillBrush" StartPoint="0%,0%" EndPoint="0%,100%" Opacity="0.25">
      <GradientStop Color="{DynamicResource AccentColor1}" Offset="0.0"/>
      <GradientStop Color="Transparent" Offset="1.0"/>
  </LinearGradientBrush>
  <SolidColorBrush x:Key="TrackBackgroundAltBrush"
                   Color="{DynamicResource TrackBackgroundAltColor}"/>
  <SolidColorBrush x:Key="NeutralAccentBrush"
                   Color="{DynamicResource NeutralAccentColor}" />
  <SolidColorBrush x:Key="NeutralAccentBrushSemi"
                   Color="{DynamicResource NeutralAccentColor}" Opacity="0.5" />
  <!-- Scrollbar thumb: single 50% tint (Fluent template must not stack extra opacity). -->
  <SolidColorBrush x:Key="ScrollBarThumbBrush"
                   Color="{DynamicResource NeutralAccentColor}" Opacity="0.5" />
  <SolidColorBrush x:Key="NeutralAccentBrushSemi2"
                   Color="{DynamicResource NeutralAccentColor}" Opacity="0.25" />
  <SolidColorBrush x:Key="PlaybackLineSolidBrush"
                   Color="{DynamicResource NeutralAccentColor}" Opacity="0.55" />
  <SolidColorBrush x:Key="NeutralAccentBrushPointerOver"
                   Color="{DynamicResource NeutralAccentColorPointerOver}" />
  <!-- Piano-roll toolbar: icon on saturated accent (selected tool / toggle on). -->
  <SolidColorBrush x:Key="ToolbarToolIconOnAccentBrush" Color="{DynamicResource ToolTipForegroundColor}" />
  <SolidColorBrush x:Key="AccentBrush1"
                   Color="{DynamicResource AccentColor1}" />
  <SolidColorBrush x:Key="AccentBrush1Semi"
                   Color="{DynamicResource AccentColor1}" Opacity="0.5" />
  <SolidColorBrush x:Key="AccentBrush1Note"
                   Color="{DynamicResource AccentColor1Note}" />
  <SolidColorBrush x:Key="AccentBrush1NoteSemi"
                   Color="{DynamicResource AccentColor1Note}" Opacity="0.5" />
  <SolidColorBrush x:Key="AccentBrush2"
                   Color="{DynamicResource AccentColor2}" />
  <SolidColorBrush x:Key="AccentBrush2Semi"
                   Color="{DynamicResource AccentColor2}" Opacity="0.5" />
  <SolidColorBrush x:Key="AccentBrush3"
                   Color="{DynamicResource AccentColor3}" />
  <SolidColorBrush x:Key="AccentBrush3Semi"
                   Color="{DynamicResource AccentColor3}" Opacity="0.5" />
  <SolidColorBrush x:Key="NoteBorderBrush"
                   Color="{DynamicResource NoteBorderColor}" />
  <SolidColorBrush x:Key="NoteBorderBrushPressed"
                   Color="{DynamicResource NoteBorderColorPressed}" />
  <SolidColorBrush x:Key="FinalPitchBrushTransparent"
                   Color="{DynamicResource FinalPitchColorTransparent}" />
  <SolidColorBrush x:Key="SelectedTrackAccentBrush"
                   Color="#4EA6EA" />
  <SolidColorBrush x:Key="SelectedTrackAccentBrushSemi"
                   Color="#4EA6EA" Opacity="0.5"/>
  <SolidColorBrush x:Key="SelectedTrackAccentLightBrush"
                   Color="#90CAF9" />
  <SolidColorBrush x:Key="SelectedTrackAccentLightBrushSemi"
                   Color="#90CAF9" Opacity="0.5"/>
  <SolidColorBrush x:Key="SelectedTrackAccentDarkBrush"
                   Color="#1E88E5" />
  <SolidColorBrush x:Key="SelectedTrackCenterKeyBrush"
                   Color="#C8E5FC" />
  <SolidColorBrush x:Key="WarningBrush"
                   Color="{DynamicResource WarningColor}" />

  <LinearGradientBrush x:Key="WhiteKeyBrush" StartPoint="0%,50%" EndPoint="100%,50%">
    <LinearGradientBrush.GradientStops>
      <GradientStop Color="{DynamicResource WhiteKeyColorLeft}" Offset="0"/>
      <GradientStop Color="{DynamicResource WhiteKeyColorRight}" Offset="1"/>
    </LinearGradientBrush.GradientStops>
  </LinearGradientBrush>
  <SolidColorBrush x:Key="WhiteKeyNameBrush"
                   Color="{DynamicResource WhiteKeyNameColor}"/>
  <LinearGradientBrush x:Key="CenterKeyBrush" StartPoint="0%,50%" EndPoint="100%,50%">
    <LinearGradientBrush.GradientStops>
      <GradientStop Color="{DynamicResource CenterKeyColorLeft}" Offset="0"/>
      <GradientStop Color="{DynamicResource CenterKeyColorRight}" Offset="1"/>
    </LinearGradientBrush.GradientStops>
  </LinearGradientBrush >
  <SolidColorBrush x:Key="CenterKeyNameBrush"
                   Color="{DynamicResource CenterKeyNameColor}"/>
  <SolidColorBrush x:Key="BlackKeyBrush"
                   Color="{DynamicResource BlackKeyColorLeft}"/>
  <SolidColorBrush x:Key="BlackKeyNameBrush"
                   Color="{DynamicResource BlackKeyNameColor}"/>
</ResourceDictionary>
